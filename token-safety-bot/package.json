{
  "name": "token-safety-bot",
  "version": "1.0.0",
  "description": "Comprehensive token safety analysis with rug detection, contract scanning, and risk assessment",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "security-check": "npm audit"
  },
  "keywords": [
    "solana",
    "cryptocurrency",
    "safety",
    "rug-pull",
    "contract-analysis",
    "defi",
    "security",
    "telegram-bot"
  ],
  "author": "SolanaIdeasLab",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "telegraf": "^4.16.3",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.9.2",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/solana-ideas-lab/token-safety-bot.git"
  },
  "bugs": {
    "url": "https://github.com/solana-ideas-lab/token-safety-bot/issues"
  },
  "homepage": "https://github.com/solana-ideas-lab/token-safety-bot#readme",
  "overrides": {
    "uuid": ">=11.1.1"
  }
}
