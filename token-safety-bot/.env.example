# Token Safety Bot — local development
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=*

# Required for production auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=7d

# Comma-separated admin wallet addresses for HTTP admin routes
ADMIN_WALLET_ADDRESSES=

# Dev-only: skip ed25519 wallet signature verification
SKIP_WALLET_SIGNATURE_VERIFY=true

# Solana RPC (Helius recommended for production)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_COMMITMENT=confirmed

# Optional Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=token_safety_bot
TELEGRAM_ADMIN_CHAT_IDS=
TELEGRAM_WEBHOOK_URL=

# Local JSON persistence (default)
DATA_STORE_PATH=./data/token-safety-store.json
SCAN_CACHE_TTL_MS=300000
MONITOR_RESCAN_INTERVAL_MS=300000

# Dev helpers
SKIP_AUTH_IN_DEV=false
ENABLE_DEBUG_LOGS=false
