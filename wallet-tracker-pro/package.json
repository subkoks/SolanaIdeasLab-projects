{
  "name": "wallet-tracker-pro",
  "version": "1.0.0",
  "description": "Professional wallet tracking with behavioral analytics, copy trading insights, and portfolio monitoring",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:patterns": "jest --testPathPattern=patterns",
    "test:performance": "jest --testPathPattern=performance",
    "test:risk": "jest --testPathPattern=risk",
    "test:integration": "jest --testPathPattern=integration",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:setup": "tsx src/scripts/setup-database.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:seed-analytics": "tsx src/scripts/seed-analytics.ts",
    "db:analyze-performance": "tsx src/scripts/analyze-performance.ts",
    "analytics-worker": "tsx src/workers/analytics-worker.ts",
    "cache:stats": "tsx src/scripts/cache-stats.ts",
    "security-check": "npm audit",
    "deploy": "docker build -t wallet-tracker-pro . && docker push wallet-tracker-pro",
    "export": "next export"
  },
