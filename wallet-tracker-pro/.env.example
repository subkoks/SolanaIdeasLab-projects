# Wallet Tracker Pro — local development
PORT=3001

DATABASE_URL=postgresql://postgres:password@localhost:5432/wallet_tracker
REDIS_URL=redis://localhost:6379

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_COMMITMENT=confirmed
JWT_SECRET=change-me-in-production

# Telegram bot MVP (npm run bot:dev)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=wallet_tracker_pro
WATCHER_POLL_INTERVAL_MS=30000
MAX_WATCHES_PER_USER=10
MOCK_SOL_USD_PRICE=150
COINGECKO_API_KEY=
PREFER_MOCK_SOL_PRICE=false

# Stripe (optional — mock /upgrade in Telegram when unset)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
WATCHER_SIGNATURE_BATCH=10
LOG_LEVEL=info

NEXT_PUBLIC_APP_NAME=Wallet Tracker Pro
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
