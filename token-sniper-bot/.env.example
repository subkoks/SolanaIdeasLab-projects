# Token Sniper Bot — local development
PORT=8000
HOST=0.0.0.0

# Required for Telegram alerts (optional for API-only dev)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=token_sniper_bot
TELEGRAM_WEBHOOK_URL=

# Postgres + Redis (created by scripts/local-dev-bootstrap.sh)
DATABASE_URL=postgresql://postgres:password@localhost:5432/token_sniper
REDIS_URL=redis://localhost:6379
QUEUE_REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
REFRESH_TOKEN_SECRET=change-me-refresh-in-production
ADMIN_WALLET_ADDRESSES=
SKIP_WALLET_SIGNATURE_VERIFY=true
SKIP_AUTH_IN_DEV=false

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_COMMITMENT=confirmed
SOLANA_NETWORK=mainnet-beta

# External APIs (optional — improves launch/holder analysis)
HELIUS_API_KEY=
PUMP_FUN_API_KEY=
JUPITER_API_KEY=
TWITTER_BEARER_TOKEN=
DEXSCREENER_API_KEY=
COINGECKO_API_KEY=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Feature flags
ENABLE_BUNDLE_DETECTION=true
ENABLE_WHALE_TRACKING=true
ENABLE_RISK_SCORING=true
ENABLE_SOCIAL_SENTIMENT=false
ENABLE_PREMIUM_FEATURES=false
MOCK_EXTERNAL_APIS=false
